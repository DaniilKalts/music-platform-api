# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=music_platform
DB_SSL_MODE=disable
DB_MIN_CONNS=1
DB_MAX_CONNS=10
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_STATEMENT_TIMEOUT=3s

# JWT authentication
JWT_ACCESS_SECRET=access-secret-change-me
JWT_REFRESH_SECRET=refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
